# Gym Access Server — Environment Variables
# Copy this file to .env and fill in your values

# SQLite (default — no external service needed):
DATABASE_URL="file:./dev.db"

# PostgreSQL (when ready for production):
# DATABASE_URL="postgresql://user:password@localhost:5432/gym_access?schema=public"

# JWT secret — change this to a long random string in production!
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# Server port
PORT=3001

# Frontend origin (for CORS)
FRONTEND_ORIGIN="http://localhost:5173"
